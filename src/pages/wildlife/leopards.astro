];

const faqs = [
  {
    question: "Are there leopards at Kanha National Park?",
    answer: "Yes, Kanha has a stable leopard population estimated at 40-50 individuals across its four zones. Leopards coexist with tigers by using different habitats (often denser forest and rocky areas), different prey (smaller deer species), and being primarily nocturnal or crepuscular."
  },
  {
    question: "Where are leopards most commonly seen at Kanha?",
    answer: "Leopards are most commonly spotted in Kisli Zone (dense Sal forest) and Kanha Zone (forest-meadow edges). They favor rocky outcrops, dense forest patches, and waterhole-adjacent areas. Afternoon safaris often produce better leopard sightings than morning shifts due to their crepuscular activity patterns."
  },
  {
    question: "Can you see leopards and tigers on the same safari?",
    answer: "Yes, it's possible to spot both leopards and tigers during the same safari, though uncommon. Leopards and tigers coexist by avoiding direct confrontation, with leopards typically using different areas than dominant tigers. Multi-day safaris covering multiple zones increase chances of seeing both species."
  },
  {
    question: "Are leopards dangerous at Kanha?",
    answer: "Leopards at Kanha are wild animals and theoretically dangerous, but incidents with safari visitors are extremely rare. Leopards generally avoid human contact and the safari setting (open vehicles, multiple people, guides present) minimizes any risk. Standard safari protocols apply for all wildlife."
  }
];

const relatedPages = [
  { title: 'Tigers', description: 'The apex predator of Kanha', href: '/kanha-tiger-guide/wildlife/tigers/' },
  { title: 'Barasingha', description: 'The swamp deer conservation story', href: '/kanha-tiger-guide/wildlife/barasingha/' },
  { title: 'Birds', description: '300+ bird species', href: '/kanha-tiger-guide/wildlife/birds/' },
  { title: 'Safari Guide', description: 'Complete safari planning', href: '/kanha-tiger-guide/safari-guide/' }
