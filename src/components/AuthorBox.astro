---
const { author='Kanha Travel Resources Editorial Team', datePublished='2026-07-18', dateModified='2026-07-18', readingTime=8 } = Astro.props;
const fp=new Date(datePublished).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'});
const fm=new Date(dateModified).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'});
---

<aside class="bg-gradient-to-br from-cream to-cream-dark dark:from-midnight-light/50 dark:to-midnight/50 border-l-4 border-coral dark:border-coral rounded-xl p-6 my-8 shadow-soft dark:shadow-soft animate-on-scroll">
  <div class="flex items-start gap-4">
    <div class="flex-shrink-0"><div class="w-14 h-14 bg-coral rounded-full flex items-center justify-center text-white text-xl shadow-sm">📝</div></div>
    <div class="flex-1 min-w-0">
      <h3 class="text-lg font-bold text-midnight dark:text-cream mb-1 font-display">About the Author</h3>
      <p class="text-sm font-semibold text-warm dark:text-gray-200 mb-2">{author}</p>
      <p class="text-sm text-warm dark:text-gray-300 mb-3 leading-relaxed">Our editorial team consists of wildlife enthusiasts, conservation researchers, and travel writers with extensive experience in India's national parks.</p>
      <div class="flex flex-wrap gap-2 text-xs">
        <span class="trust-badge">✓ Fact-Checked</span>
        <span class="trust-badge bg-coral/10 text-coral-dark dark:text-coral-light border-coral/20">📅 Published {fp}</span>
        {fm!==fp&&<span class="trust-badge bg-amber-50 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300 border-amber-200 dark:border-amber-700">🔄 Updated {fm}</span>}
        <span class="trust-badge bg-purple-50 dark:bg-purple-900/30 text-purple-800 dark:text-purple-300 border-purple-200 dark:border-purple-700">⏱ {readingTime} min read</span>
      </div>
    </div>
  </div>
</aside>