---
const { pages=[], title="Related Resources" } = Astro.props;
---

<section class="my-12">
  <h2 class="text-2xl md:text-3xl font-bold text-midnight dark:text-cream mb-6 font-display">{title}</h2>
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
    {pages.map(p => (
      <a href={p.href} class="block bg-white dark:bg-midnight-light p-5 rounded-lg shadow-card dark:shadow-card hover:shadow-card-hover transition border-l-4 border-coral dark:border-coral">
        <h3 class="text-lg font-bold text-midnight dark:text-cream mb-2">{p.title} →</h3>
        <p class="text-sm text-warm dark:text-gray-400">{p.description}</p>
      </a>
    ))}
  </div>
</section>