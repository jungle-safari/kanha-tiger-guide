---
const navItems = [
  { label: 'Home', href: '/kanha-tiger-guide/' },
  { label: 'Safari Guide', href: '/kanha-tiger-guide/safari-guide/' },
  { label: 'Resorts', href: '/kanha-tiger-guide/resorts/' },
  { label: 'Safari Zones', href: '/kanha-tiger-guide/safari-zones/' },
  { label: 'Wildlife', href: '/kanha-tiger-guide/wildlife/' },
  { label: 'Travel Info', href: '/kanha-tiger-guide/travel-info/' }
];

const currentPath = Astro.url.pathname;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const isActive = (href) => currentPath === href || (href !== '/kanha-tiger-guide/' && currentPath.startsWith(href));
---

<a href="#main-content" class="skip-link">Skip to main content</a>

<!-- Top splash bar -->
<div class="bg-gradient-to-r from-midnight to-midnight-light dark:from-gray-900 dark:to-midnight text-white text-xs py-1.5 border-b border-coral/20">
  <div class="max-w-7xl mx-auto px-4 flex flex-wrap items-center justify-between gap-2">
    <div class="flex items-center gap-3">
      <span class="flex items-center gap-1"><span class="text-coral">📅</span> Updated July 2026</span>
      <span class="hidden sm:flex items-center gap-1 bg-white/10 px-2 py-0.5 rounded-full"><span class="text-coral">★</span> India's #1 Kanha Resource</span>
      <span class="hidden lg:flex items-center gap-1"><span class="text-teal">◆</span> Independent &amp; Unbiased</span>
    </div>
    <div class="flex items-center gap-2">
      <span class="hidden md:inline text-gray-300 dark:text-gray-400">Trusted by 50,000+ travelers</span>
      <span class="hidden md:inline text-gray-500">|</span>
      <span class="hidden md:flex items-center gap-1 text-coral-light">📞 +91 77198 06444</span>
    </div>
  </div>
</div>

<!-- Header -->
<header class="bg-white/95 dark:bg-midnight-light/95 backdrop-blur-md shadow-soft sticky top-0 z-50 border-b border-gray-100 dark:border-midnight-lighter">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between gap-4 py-3">
      <a href="/kanha-tiger-guide/" class="flex items-center gap-3 group" aria-label="Kanha Tiger Guide Home">
        <div class="relative">
          <img src={`${basePath}/images/logo.webp`} alt="" class="h-12 w-12 rounded-full object-cover ring-2 ring-coral/20 group-hover:ring-coral/40 transition-all" width="48" height="48" loading="eager" />
          <div class="absolute -bottom-1 -right-1 w-4 h-4 bg-coral rounded-full flex items-center justify-center ring-2 ring-white dark:ring-midnight-light">
            <span class="text-white text-[8px] font-bold">◆</span>
          </div>
        </div>
        <div>
          <div class="text-xl md:text-2xl font-bold text-midnight dark:text-cream font-display leading-tight">Kanha Tiger Guide</div>
          <div class="text-xs text-warm dark:text-gray-400">Independent Travel Resource Since 2020</div>
        </div>
      </a>

      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {navItems.map(item => (
          <a href={item.href}
            class={`px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${
              isActive(item.href)
                ? 'bg-coral text-white shadow-sm shadow-coral/20'
                : 'text-warm dark:text-gray-300 hover:bg-cream dark:hover:bg-midnight hover:text-midnight dark:hover:text-cream'
            }`}
            aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>
        ))}
      </nav>

      <button id="mobile-menu-btn"
        class="lg:hidden p-2.5 rounded-lg hover:bg-cream dark:hover:bg-midnight transition-colors text-warm dark:text-gray-300"
        aria-label="Toggle navigation menu" aria-expanded="false"
        onclick="this.ariaExpanded=this.ariaExpanded==='false'?'true':'false';document.getElementById('mobile-menu').classList.toggle('hidden')">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>

    <nav id="mobile-menu" class="hidden lg:hidden pb-4 space-y-1 border-t border-gray-100 dark:border-midnight-lighter pt-3">
      {navItems.map(item => (
        <a href={item.href}
          class={`block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors ${
            isActive(item.href) ? 'bg-coral text-white' : 'text-warm dark:text-gray-300 hover:bg-cream dark:hover:bg-midnight'
          }`}
          aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>
      ))}
      <a href="https://kanhasafaristay.com/" rel="dofollow noopener" target="_blank"
         class="block mt-2 px-4 py-2.5 bg-cream dark:bg-midnight text-midnight dark:text-cream rounded-lg text-sm font-semibold text-center border border-coral/30 dark:border-teal/30 hover:bg-coral/10 transition-colors">
        🐅 Book Kanha Safari Package
      </a>
    </nav>
  </div>
</header>

<script>
  const btn=document.getElementById('mobile-menu-btn'),menu=document.getElementById('mobile-menu');
  btn&&menu&&btn.addEventListener('click',()=>{btn.setAttribute('aria-expanded',String(menu.classList.contains('hidden')))});
</script>