---
const { currentPath } = Astro.props;
const quickFacts = [
  { label: 'Park Area', value: '940 sq km' }, { label: 'Tiger Population', value: '~125 (2024)' },
  { label: 'Safari Zones', value: '4 zones' }, { label: 'Open Season', value: 'Oct 1 – Jun 30' },
  { label: 'Nearest Airport', value: 'Jabalpur (165 km)' }
];
const packageLinks = [
  { text: 'Kanha Safari Tour Package', url: 'https://kanhasafaristay.com/package/kanha-safari-tour-package/' },
  { text: 'Kanha Jungle Safari Package', url: 'https://kanhasafaristay.com/package/kanha-jungle-safari-package/' },
  { text: 'Kanha Kisli Tour Package', url: 'https://kanhasafaristay.com/package/kanha-kisli-tour-package/' },
  { text: 'Mukki Zone Tour Package', url: 'https://kanhasafaristay.com/package/mukki-zone-tour-package/' },
  { text: 'Kanha Leisure Tour Package', url: 'https://kanhasafaristay.com/package/kanha-leisure-tour-package/' }
];
const popularArticles = [
  { title: 'How to Spot Tigers at Kanha', href: '/kanha-tiger-guide/wildlife/tigers/', readTime: '8 min', tag: 'Tigers' },
  { title: 'Kanha Zone vs Kisli Zone', href: '/kanha-tiger-guide/safari-zones/kanha-zone/', readTime: '6 min', tag: 'Zones' },
  { title: 'Best Time to Visit for Tigers', href: '/kanha-tiger-guide/travel-info/best-time/', readTime: '7 min', tag: 'Planning' },
  { title: 'How to Reach Kanha from Jabalpur', href: '/kanha-tiger-guide/travel-info/how-to-reach/', readTime: '5 min', tag: 'Travel' },
  { title: 'Barasingha Conservation Story', href: '/kanha-tiger-guide/wildlife/barasingha/', readTime: '9 min', tag: 'Wildlife' },
  { title: 'Mukki Zone Tiger Density', href: '/kanha-tiger-guide/safari-zones/mukki-zone/', readTime: '7 min', tag: 'Zones' },
  { title: 'Safari Permit Costs 2026', href: '/kanha-tiger-guide/safari-guide/pricing/', readTime: '6 min', tag: 'Safari' }
];
---

<aside class="space-y-6">
  <!-- Quick Facts -->
  <div class="bg-white dark:bg-midnight-light rounded-xl shadow-card dark:shadow-card p-6 border-t-4 border-coral dark:border-coral transition-shadow hover:shadow-card-hover">
    <h3 class="text-lg font-bold text-midnight dark:text-cream mb-4 flex items-center gap-2 font-display">
      <span class="w-7 h-7 bg-coral/10 dark:bg-coral/20 rounded-full flex items-center justify-center text-sm">◆</span> Quick Facts
    </h3>
    <dl class="space-y-2 text-sm">
      {quickFacts.map(f => (
        <div class="flex justify-between items-center py-1.5 border-b border-gray-100 dark:border-midnight-lighter last:border-0">
          <dt class="text-warm dark:text-gray-400">{f.label}</dt><dd class="font-semibold text-midnight dark:text-cream">{f.value}</dd>
        </div>
      ))}
    </dl>
  </div>

  <!-- Packages -->
  <div class="bg-gradient-to-br from-cream to-cream-dark dark:from-midnight-light/50 dark:to-midnight/50 rounded-xl shadow-card dark:shadow-card p-5 border-t-4 border-coral">
    <h3 class="text-sm font-bold text-midnight dark:text-cream mb-3 flex items-center gap-2">🐅 Kanha Safari Packages</h3>
    <ul class="space-y-2.5">
      {packageLinks.map(l => (
        <li><a href={l.url} rel="dofollow noopener" target="_blank" class="text-xs font-medium text-warm dark:text-gray-300 hover:text-coral dark:hover:text-coral-light hover:underline flex items-start gap-1.5 leading-tight transition-colors" title={l.text}><span class="text-coral mt-0.5">→</span><span>{l.text}</span></a></li>
      ))}
    </ul>
    <a href="https://kanhasafaristay.com/package/" rel="dofollow noopener" target="_blank" class="block mt-3 text-xs font-bold text-coral-dark dark:text-coral-light hover:text-coral hover:underline text-center bg-coral/10 dark:bg-coral/10 rounded-lg py-2 transition-colors">View All Packages →</a>
  </div>

  <!-- Popular -->
  <div class="bg-white dark:bg-midnight-light rounded-xl shadow-card dark:shadow-card p-6 border-t-4 border-teal transition-shadow hover:shadow-card-hover">
    <h3 class="text-lg font-bold text-midnight dark:text-cream mb-4 flex items-center gap-2 font-display">
      <span class="w-7 h-7 bg-teal/10 dark:bg-teal/20 rounded-full flex items-center justify-center text-sm">◆</span> Most Popular
    </h3>
    <ol class="space-y-3">
      {popularArticles.map((a,i) => (
        <li class="flex items-start gap-3 group">
          <span class="flex-shrink-0 w-6 h-6 bg-teal/10 dark:bg-teal/20 text-teal-dark dark:text-teal-light rounded-full flex items-center justify-center text-xs font-bold mt-0.5">{i+1}</span>
          <div class="flex-1 min-w-0">
            <a href={a.href} class="text-sm font-medium text-midnight dark:text-gray-200 group-hover:text-coral dark:group-hover:text-coral-light transition leading-tight block">{a.title}</a>
            <div class="flex items-center gap-2 mt-1"><span class="text-[10px] font-medium text-teal-dark dark:text-teal-light bg-teal/10 dark:bg-teal/20 px-1.5 py-0.5 rounded">{a.tag}</span><span class="text-xs text-warm dark:text-gray-400">⏱ {a.readTime}</span></div>
          </div>
        </li>
      ))}
    </ol>
  </div>

  <!-- CTA -->
  <div class="bg-gradient-to-br from-teal/5 to-teal/10 dark:from-teal/10 dark:to-teal/5 rounded-xl shadow-card dark:shadow-card p-6 border-2 border-teal/30 dark:border-teal/30 transition-shadow hover:shadow-card-hover">
    <div class="text-center">
      <div class="text-3xl mb-2">🏨</div>
      <h3 class="text-lg font-bold text-midnight dark:text-cream mb-2 font-display">Book Kanha Resort Stay</h3>
      <p class="text-xs text-warm dark:text-gray-300 mb-4 leading-relaxed">Complete Kanha safari packages from the best resort near Khatia Gate — AC accommodation, meals, permits & guided jeep tours.</p>
      <a href="https://kanhasafaristay.com/wild-mark-resort-kanha-accommodation/" rel="dofollow noopener" target="_blank" class="block bg-coral text-white px-4 py-2.5 rounded-lg font-semibold hover:bg-coral-dark transition text-sm shadow-sm" title="Wildmark Resort Kanha Accommodation">View Kanha Accommodation →</a>
      <div class="mt-3 space-y-1.5">
        <a href="https://kanhasafaristay.com/blog/" rel="dofollow noopener" target="_blank" class="block text-teal-dark dark:text-teal-light text-xs font-semibold hover:underline">📚 Kanha Safari Blog →</a>
        <a href="https://kanhasafaristay.com/faq/" rel="dofollow noopener" target="_blank" class="block text-teal-dark dark:text-teal-light text-xs font-semibold hover:underline">❓ Kanha Safari FAQ →</a>
        <a href="https://kanhasafaristay.com/how-to-reach-kanha/" rel="dofollow noopener" target="_blank" class="block text-teal-dark dark:text-teal-light text-xs font-semibold hover:underline">✈️ How to Reach Kanha →</a>
      </div>
      <p class="text-xs text-warm dark:text-gray-400 mt-3 bg-white/60 dark:bg-black/20 rounded-lg py-1.5">📞 +91 77198 06444</p>
    </div>
  </div>

  <!-- Trust -->
  <div class="bg-gradient-to-br from-teal/5 to-teal/10 dark:from-teal/10 dark:to-teal/5 rounded-xl shadow-card dark:shadow-card p-5 border border-teal/20 dark:border-teal/20">
    <div class="flex items-center gap-2 mb-2">
      <span class="w-8 h-8 bg-teal/10 dark:bg-teal/20 rounded-full flex items-center justify-center text-teal-dark dark:text-teal-light text-sm font-bold">✓</span>
      <h4 class="font-bold text-midnight dark:text-cream text-sm font-display">Verified Information</h4>
    </div>
    <p class="text-xs text-warm dark:text-gray-300 leading-relaxed">All data sourced from Madhya Pradesh Forest Department, All India Tiger Estimation 2024, and verified by our wildlife research team.</p>
    <div class="mt-3 flex flex-wrap gap-1.5">
      <span class="text-[10px] bg-teal/10 dark:bg-teal/20 text-teal-dark dark:text-teal-light px-2 py-0.5 rounded-full font-medium">Forest Dept</span>
      <span class="text-[10px] bg-teal/10 dark:bg-teal/20 text-teal-dark dark:text-teal-light px-2 py-0.5 rounded-full font-medium">Tiger Census</span>
      <span class="text-[10px] bg-teal/10 dark:bg-teal/20 text-teal-dark dark:text-teal-light px-2 py-0.5 rounded-full font-medium">Verified</span>
    </div>
  </div>
</aside>