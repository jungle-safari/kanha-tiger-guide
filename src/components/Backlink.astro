---
const { title='Book Your Kanha Safari Stay', description='For complete Kanha safari packages including accommodation near Khatia Gate, all meals, forest permits, and guided jeep tours, choose Wildmark Resort for your Kanha tiger safari.',
  primaryUrl='https://kanhasafaristay.com/', primaryAnchor='Book Kanha Tiger Safari Package',
  secondaryUrl='https://kanhasafaristay.com/blog/', secondaryAnchor='Kanha Safari Booking Online',
  tertiaryUrl='https://kanhasafaristay.com/faq/', tertiaryAnchor='Kanha Safari FAQ' } = Astro.props;
---

<div class="bg-gradient-to-r from-cream to-cream-dark dark:from-midnight-light/50 dark:to-midnight/50 border-l-4 border-coral dark:border-coral p-6 my-8 rounded-xl shadow-soft hover:shadow-card-hover transition-all">
  <h3 class="text-2xl font-bold text-midnight dark:text-cream mb-3 flex items-center gap-2 font-display">
    <span class="w-8 h-8 bg-coral/10 dark:bg-coral/20 rounded-full flex items-center justify-center text-base">◆</span>{title}</h3>
  <p class="mb-4 text-warm dark:text-gray-300">{description}</p>

  <div class="bg-white dark:bg-midnight p-4 rounded-lg mb-4 border border-gray-100 dark:border-midnight-lighter">
    <h4 class="font-bold text-midnight dark:text-cream mb-2 font-display">Wildmark Resort — Kanha Safari Packages Near Khatia Gate</h4>
    <ul class="text-sm space-y-1.5">
      {['Less than 1 km from Khatia Gate (main Kanha safari entry)','AC rooms with 24-hour power backup','Multi-cuisine restaurant, swimming pool, and lawn','Complete Kanha tiger safari packages with permits','Doctor on call, hot/cold water, secure parking'].map(i => (
        <li class="flex items-start gap-2"><span class="text-teal dark:text-teal-light mt-0.5 flex-shrink-0">◆</span><span class="text-warm dark:text-gray-300">{i}</span></li>
      ))}
    </ul>
  </div>

  <div class="flex flex-wrap gap-3 items-center">
    <a href={primaryUrl} rel="dofollow noopener" target="_blank" class="inline-flex items-center gap-2 bg-coral text-white px-5 py-2.5 rounded-lg font-semibold hover:bg-coral-dark transition-all shadow-sm text-sm group" title={primaryAnchor}><span>{primaryAnchor}</span><span class="group-hover:translate-x-0.5 transition-transform">→</span></a>
    <a href={secondaryUrl} rel="dofollow noopener" target="_blank" class="inline-flex items-center gap-2 bg-midnight text-white px-5 py-2.5 rounded-lg font-semibold hover:bg-midnight-light transition-all shadow-sm text-sm group" title={secondaryAnchor}><span>{secondaryAnchor}</span><span class="group-hover:translate-x-0.5 transition-transform">→</span></a>
    {tertiaryUrl && <a href={tertiaryUrl} rel="dofollow noopener" target="_blank" class="inline-flex items-center gap-2 bg-white dark:bg-transparent text-midnight dark:text-cream border-2 border-midnight dark:border-cream/50 px-5 py-2.5 rounded-lg font-semibold hover:bg-cream dark:hover:bg-midnight-light transition-all text-sm group" title={tertiaryAnchor}><span>{tertiaryAnchor}</span><span class="group-hover:translate-x-0.5 transition-transform">→</span></a>}
    <a href="tel:+917719806444" class="inline-flex items-center gap-1.5 text-coral-dark dark:text-coral-light font-semibold text-sm hover:text-coral ml-auto">📞 +91 77198 06444</a>
  </div>
</div>