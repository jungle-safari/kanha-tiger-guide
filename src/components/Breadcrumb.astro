---
const { items } = Astro.props;
const schema = {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":items.map((i,idx)=>({"@type":"ListItem","position":idx+1,"name":i.label,"item":`https://jungle-safari.github.io/kanha-tiger-guide${i.href}`}))};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<nav class="text-sm mb-4 text-warm dark:text-gray-400" aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-2">
    {items.map((item,i)=>(
      <li class="flex items-center gap-2">
        {i>0&&<svg class="w-3.5 h-3.5 text-warm dark:text-gray-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>}
        {i===items.length-1 ? <span class="text-midnight dark:text-cream font-semibold" aria-current="page">{item.label}</span> : <a href={item.href} class="text-coral dark:text-coral-light hover:text-coral-dark dark:hover:text-coral transition-colors">{item.label}</a>}
      </li>
    ))}
  </ol>
</nav>