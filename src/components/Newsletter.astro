<aside class="bg-gradient-to-br from-midnight to-midnight-light dark:from-gray-900 dark:to-midnight text-white rounded-xl p-8 my-10 shadow-elevated dark:shadow-elevated animate-on-scroll">
  <div class="text-center max-w-2xl mx-auto">
    <div class="inline-flex items-center gap-1.5 bg-coral text-white px-3 py-1 rounded-full text-xs font-bold mb-3">📧 FREE TRAVEL GUIDE</div>
    <h3 class="text-2xl md:text-3xl font-bold mb-3 font-display">Get the Complete Kanha Safari Planning Guide</h3>
    <p class="text-gray-300 dark:text-gray-300 mb-6 leading-relaxed">Join 50,000+ travelers who get our weekly tips on tiger safaris, wildlife photography, and exclusive access to Kanha wildlife information.</p>
    <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto mb-4" onsubmit="event.preventDefault();alert('Thank you!');this.reset()">
      <label for="newsletter-email" class="sr-only">Email address</label>
      <input id="newsletter-email" type="email" placeholder="Enter your email address" class="flex-1 px-4 py-3 rounded-lg text-gray-800 focus:outline-none focus:ring-2 focus:ring-coral placeholder:text-gray-400" required autocomplete="email" />
      <button type="submit" class="bg-coral text-white px-6 py-3 rounded-lg font-bold hover:bg-coral-dark transition-all hover:scale-[1.02] active:scale-[0.98]">Send Me the Guide</button>
    </form>
    <div class="flex items-center justify-center gap-4 text-xs text-gray-400 flex-wrap"><span>🔒 Privacy protected</span><span class="hidden sm:inline">•</span><span>📨 Weekly updates</span><span class="hidden sm:inline">•</span><span>❌ No spam</span></div>
  </div>
</aside>